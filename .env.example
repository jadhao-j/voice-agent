# LLM Provider: local (default, no API key), huggingface (free local), openai, anthropic
LLM_PROVIDER=local

# Local LLM using HuggingFace (optional, free, no API key required)
USE_HUGGINGFACE_LOCAL=false
HUGGINGFACE_MODEL=microsoft/DialoGPT-small

# OpenAI Configuration (optional, requires API key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Anthropic Configuration (optional, requires API key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
